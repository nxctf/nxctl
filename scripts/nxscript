#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="${NXCTL_PROJECT_DIR:-$(cd "$SCRIPT_PATH/.." && pwd)}"

# shellcheck source=lib/args.sh
source "$PROJECT_DIR/scripts/lib/args.sh"

usage() {
  cat <<'EOF'
Usage: nxscript [common flags] <command> [args]

Common flags:
  -v, --verbose
  --no-spinner
  -h, --help

Commands:
  uninstall
  update
  api [1|2|3|4|5|all]
  cloudflared create <tunnel> <count> [domain]
  cloudflared delete <tunnel> [domain]
  service start|stop|restart|status
EOF
}

parse_common_flags "$@"
set -- "${NXSCRIPT_POSITIONAL_ARGS[@]}"

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$COMMAND" in
  uninstall)
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      exec bash "$PROJECT_DIR/scripts/uninstall.sh" --help
    fi
    exec bash "$PROJECT_DIR/scripts/uninstall.sh" "$@"
    ;;
  update)
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      exec bash "$PROJECT_DIR/scripts/update.sh" --help
    fi
    exec bash "$PROJECT_DIR/scripts/update.sh" "$@"
    ;;
  api)
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      exec bash "$PROJECT_DIR/scripts/api.sh" "$@" --help
    fi
    exec bash "$PROJECT_DIR/scripts/api.sh" "$@"
    ;;
  cloudflared|cloudflare)
    export NXCF_COMMAND_NAME="nxscript cloudflared"
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      exec bash "$PROJECT_DIR/scripts/cloudflared.sh" "$@" --help
    fi
    exec bash "$PROJECT_DIR/scripts/cloudflared.sh" "$@"
    ;;
  service)
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      exec bash "$PROJECT_DIR/scripts/service.sh" "$@" --help
    fi
    exec bash "$PROJECT_DIR/scripts/service.sh" "$@"
    ;;
  help)
    usage
    ;;
  *)
    if [[ "$NXSCRIPT_HELP" -eq 1 ]]; then
      usage
      exit 0
    fi
    if [[ "$COMMAND" == "install" ]]; then
      echo "nxscript install has been removed; use ./setup.sh install instead" >&2
      echo "Run: ./setup.sh install" >&2
      exit 1
    fi
    if [[ "$COMMAND" == "delete" ]]; then
      echo "nxscript delete is not a public command; use scripts/delete.sh directly if needed" >&2
      echo "Run: bash scripts/delete.sh --help" >&2
      exit 1
    fi
    if [[ "$COMMAND" == "completion" ]]; then
      echo "nxscript completion is not a public command; use scripts/completion/*.sh directly if needed" >&2
      echo "Run: bash scripts/completion/install.sh --help" >&2
      exit 1
    fi
    echo "Unknown nxscript command: $COMMAND" >&2
    echo "Run: nxscript --help" >&2
    exit 1
    ;;
esac
