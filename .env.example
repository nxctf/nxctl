# NXCTL environment example
#
# Copy to .env and fill only what you need. Never commit real secrets.

# GitHub token is only needed for private challenge repositories.
GITHUB_TOKEN=your-github-token

# Normal API client token.
# If set, API clients must send one of:
#   Authorization: Bearer <token>
#   X-NXCTL-Token: <token>
NXCTL_API_TOKEN=your-api-client-token

# Admin secret for dangerous/global API actions:
#   POST /sync
#   POST /up?all=true
#   POST /down/{name}
#   POST /down?all=true
#
# Send with:
#   X-NXCTL-Admin-Secret: <secret>
NXCTL_API_ADMIN_SECRET=your-admin-secret

# Ngrok tokens. NXCTL can rotate across multiple free accounts/tokens.
NGROK_TOKEN_1=your-ngrok-token-1
NGROK_TOKEN_2=your-ngrok-token-2
NGROK_TOKEN_3=your-ngrok-token-3
# NGROK_TOKEN_4=your-ngrok-token-4
# NGROK_TOKEN_5=your-ngrok-token-5
# NGROK_TOKEN_6=your-ngrok-token-6
# NGROK_TOKEN_7=your-ngrok-token-7
# NGROK_TOKEN_8=your-ngrok-token-8
# NGROK_TOKEN_9=your-ngrok-token-9
# NGROK_TOKEN_10=your-ngrok-token-10

PINGGY_TOKEN_1=your-pinggy-token-1
PINGGY_TOKEN_2=your-pinggy-token-2

# Cloudflare Named Tunnel configurations (Optional)
CLOUDFLARE_TUNNEL_NAME=edge
CLOUDFLARE_CREDENTIALS_FILE=/home/vagrant/.cloudflared/2b865acf-2600-4e55-bfc9-d48294f6b6a4.json
CLOUDFLARE_SUBDOMAIN_A=a.nxctf.my.id
CLOUDFLARE_SUBDOMAIN_B=b.nxctf.my.id
CLOUDFLARE_SUBDOMAIN_C=c.nxctf.my.id
CLOUDFLARE_SUBDOMAIN_D=d.nxctf.my.id
CLOUDFLARE_SUBDOMAIN_E=e.nxctf.my.id
