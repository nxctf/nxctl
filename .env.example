# Environment variables for CTF Orchestration Engine
# Copy this to .env and fill in your actual values

# GitHub Repository Token (for private repos)
GITHUB_TOKEN=your-github-token-here

# FRP Tunnel Tokens
FRP_TOKEN_PRIMARY=your-frp-primary-token
FRP_TOKEN_SECONDARY=your-frp-secondary-token

# ngrok Tunnel Tokens (for multiple accounts)
NGROK_TOKEN_1=your-ngrok-token-1
NGROK_TOKEN_2=your-ngrok-token-2
NGROK_TOKEN_3=your-ngrok-token-3

# Rathole Tunnel Tokens
RATHOLE_TOKEN_1=your-rathole-token-1
RATHOLE_TOKEN_2=your-rathole-token-2

# Cloudflare Tunnel Token (optional, currently not in MVP)
# CLOUDFLARE_TOKEN=your-cloudflare-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id
