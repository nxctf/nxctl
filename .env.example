# Environment variables for CTF Orchestration Engine
# Copy this to .env and fill in your actual values
#
# HOSTED TUNNEL PROVIDERS ONLY
# All providers below are FREE and require no self-hosted infrastructure

# GitHub Repository Token (for private repos)
# GITHUB_TOKEN=your-github-token-here

# ngrok Tunnel Tokens
# Sign up at https://ngrok.com (free tier: 4 concurrent tunnels)
NGROK_TOKEN_1=your-ngrok-token-1
NGROK_TOKEN_2=your-ngrok-token-2

# localtunnel: No token needed! Just random subdomains
# Free unlimited tunnels via https://localtunnel.me
# Uses auto-generated subdomain names

# serveo: No token needed! Direct SSH-based tunneling
# Free unlimited tunnels via https://serveo.net
# Uses random or custom subdomains

# pinggy: No token needed! Simple URL-based tunneling
# Free tier (2 concurrent) via https://pinggy.io
# Uses auto-generated short URLs
